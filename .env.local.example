# Copy this file to .env.local and fill in your values

# NextAuth — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_64_char_hex_secret_here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App — create at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# AES-256-GCM key for encrypting GitHub tokens at rest — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# Stellar network: "testnet" or "mainnet"
STELLAR_NETWORK=mainnet
NEXT_PUBLIC_STELLAR_NETWORK=mainnet

# Optional: Upstash Redis for persistent storage in production
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=your_upstash_token

# Optional: Anthropic Claude for AI-generated listing descriptions
# ANTHROPIC_API_KEY=sk-ant-...
