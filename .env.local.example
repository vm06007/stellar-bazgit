# ── Local development (.env.local) ───────────────────────────────────────────
# Copy to .env.local and fill in. For production, see .env.production.example.

# NextAuth — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your_64_char_hex_secret_here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# AES-256-GCM key for encrypting GitHub tokens at rest — openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here

# Stellar network: "testnet" (recommended for dev) or "mainnet"
STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Stellar address that collects the 0.5% platform fee
STELLAR_TREASURY_ADDRESS=G...

# AI agent — one of these (OpenRouter or Anthropic)
OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional in dev: Upstash Redis (falls back to .data/*.json files locally)
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=your_upstash_token
