# ── Production environment ───────────────────────────────────────────────────
# Set these in your host's env (Vercel project settings, Fly secrets, etc.).
# Do NOT commit real values. Generate fresh secrets — never reuse dev secrets.
#
# ┌─ GitHub OAuth App (create a SEPARATE app for production) ───────────────────┐
# │ https://github.com/settings/developers → New OAuth App                      │
# │   Application name:          Stellar Bazgit                                 │
# │   Homepage URL:              https://your-domain.com                        │
# │   Authorization callback URL https://your-domain.com/api/auth/callback/github│
# │ Then "Generate a new client secret" and copy both values below.            │
# └─────────────────────────────────────────────────────────────────────────────┘

# Full canonical URL of the deployment — MUST match the domain exactly (https).
NEXTAUTH_URL=https://your-domain.com

# NextAuth session signing key — generate fresh: openssl rand -base64 32
NEXTAUTH_SECRET=

# Production GitHub OAuth app credentials (from the app created above)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AES-256-GCM key encrypting sellers' GitHub tokens at rest.
# Generate fresh: openssl rand -hex 32   (64 hex chars exactly)
# WARNING: changing this later makes existing encrypted tokens unreadable.
TOKEN_ENCRYPTION_KEY=

# Stellar network for real payments
STELLAR_NETWORK=mainnet
NEXT_PUBLIC_STELLAR_NETWORK=mainnet

# Stellar address that receives the 0.5% platform fee
STELLAR_TREASURY_ADDRESS=G...

# AI agent provider — one of these
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=

# ── Upstash Redis — REQUIRED in production ───────────────────────────────────
# Serverless filesystems are ephemeral, so .data/*.json will NOT persist.
# Create a free DB at https://console.upstash.com and paste the REST creds.
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=
